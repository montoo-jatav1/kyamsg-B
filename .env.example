# Copy to .env and fill in real values before deploying. NEVER commit the real .env.
DATABASE_URL=jdbc:postgresql://localhost:5432/sandeshx
DATABASE_USER=sandeshx
DATABASE_PASSWORD=change-me

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me

# Generate with: openssl rand -hex 32 — must be long/random, never a default in prod
JWT_SECRET=

# Comma-free single origin your Android/web app is served from, e.g. https://sandeshx.app
ALLOWED_ORIGIN=

# Plug in Twilio/MSG91 credentials here once you replace LogSmsSender with a real provider
SMS_PROVIDER_API_KEY=
